<system>
    <memory_region name="bootinfo" prefill_bootinfo="x86_tsc_freq" />

    <protection_domain name="mr_bootinfo" priority="100" >
        <program_image path="mr_bootinfo.elf" />
        <map mr="bootinfo" vaddr="0x20000000" setvar_vaddr="bootinfo_mr" />
    </protection_domain>
</system>
